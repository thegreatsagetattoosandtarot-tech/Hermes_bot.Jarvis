            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Write to CRM File": {
      "main": [
        [
          {
            "node": "Notify JARVIS via Convos",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
